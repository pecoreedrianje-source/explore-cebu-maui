<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CebuFinalApp.ProfilePage"
             BackgroundColor="#F4F9F8">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" Padding="15,0" BackgroundColor="#4DBBB7" HeightRequest="56">
            <Label Text="My Profile" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ─── Header Banner ─────────────────────────────────── -->
            <Grid HeightRequest="130" BackgroundColor="#4DBBB7">
                <BoxView Color="#38A89D" HeightRequest="60" VerticalOptions="End" />
            </Grid>

            <!-- ─── Avatar + Background Picture ──────────────────── -->
            <Grid Margin="0,-60,0,0" HorizontalOptions="Center">

                <!-- Background picture behind avatar -->
                <Frame HeightRequest="110" WidthRequest="110"
                       CornerRadius="55" Padding="0"
                       IsClippedToBounds="True"
                       BorderColor="White"
                       BackgroundColor="#4DBBB7"
                       HorizontalOptions="Center">
                    <Image x:Name="BackgroundImage"
                           Source="cebu_beach.jpg"
                           Aspect="AspectFill"
                           Opacity="0.4" />
                </Frame>

                <!-- Profile avatar on top -->
                <Frame HeightRequest="90" WidthRequest="90"
                       CornerRadius="45" Padding="0"
                       IsClippedToBounds="True"
                       BorderColor="White"
                       BackgroundColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Image x:Name="ProfileImage"
                           Source="dotnet_bot.png"
                           Aspect="AspectFill" />
                </Frame>

                <!-- Camera button for profile picture -->
                <Button Clicked="OnEditPictureTapped"
                        HeightRequest="30" WidthRequest="30"
                        CornerRadius="15"
                        BackgroundColor="#4DBBB7"
                        Text="&#xf030;"
                        FontFamily="FASolid"
                        FontSize="12"
                        TextColor="White"
                        VerticalOptions="End"
                        HorizontalOptions="End"
                        Margin="0,0,2,2" />

                <!-- Image button for background picture -->
                <Button Clicked="OnEditBackgroundTapped"
                        HeightRequest="30" WidthRequest="30"
                        CornerRadius="15"
                        BackgroundColor="#718096"
                        Text="&#xf03e;"
                        FontFamily="FASolid"
                        FontSize="12"
                        TextColor="White"
                        VerticalOptions="Start"
                        HorizontalOptions="End"
                        Margin="0,2,2,0" />
            </Grid>

            <!-- ─── Name + Email ──────────────────────────────────── -->
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,10,0,0">
                <Label x:Name="UserNameLabel"
                       Text="Cebu Traveler"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#2D3748"
                       HorizontalOptions="Center" />
                <Label x:Name="UserEmailLabel"
                       Text="user@email.com"
                       FontSize="13"
                       TextColor="#718096"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- ─── Stats Row ─────────────────────────────────────── -->
            <Frame Margin="20,18,20,0"
                   Padding="15,12"
                   CornerRadius="16"
                   HasShadow="False"
                   BorderColor="Transparent"
                   BackgroundColor="White">
                <Grid ColumnDefinitions="*,Auto,*,Auto,*">

                    <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center">
                        <Label x:Name="FavoritesCountLabel"
                               Text="0"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#4FD1C5"
                               HorizontalOptions="Center" />
                        <Label Text="Favorites"
                               FontSize="11"
                               TextColor="#718096"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <BoxView Grid.Column="1" Color="#E2E8F0" WidthRequest="1" HeightRequest="40" VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center">
                        <Label x:Name="VisitedCountLabel"
                               Text="0"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#F6AD55"
                               HorizontalOptions="Center" />
                        <Label Text="Visited"
                               FontSize="11"
                               TextColor="#718096"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <BoxView Grid.Column="3" Color="#E2E8F0" WidthRequest="1" HeightRequest="40" VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="4" Spacing="3" HorizontalOptions="Center">
                        <Label x:Name="ReviewsCountLabel"
                               Text="0"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#9F7AEA"
                               HorizontalOptions="Center" />
                        <Label Text="Reviews"
                               FontSize="11"
                               TextColor="#718096"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                </Grid>
            </Frame>

            <!-- ─── Account Settings ──────────────────────────────── -->
            <Label Text="Account" FontSize="13" FontAttributes="Bold"
                   TextColor="#718096" Margin="25,22,20,8" />

            <VerticalStackLayout Margin="20,0" Spacing="10">

                <!-- Edit Profile -->
                <Frame CornerRadius="14" Padding="16,14" HasShadow="False"
                       BorderColor="Transparent" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnEditProfileTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="36, *, Auto">
                        <Frame Grid.Column="0" WidthRequest="36" HeightRequest="36"
                               CornerRadius="10" Padding="0" HasShadow="False"
                               BackgroundColor="#EBF8FF" BorderColor="Transparent">
                            <Image Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf007;', Color='#4299E1', Size=16}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center" Spacing="1">
                            <Label Text="Edit Profile" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" />
                            <Label Text="Update your name and photo" FontSize="11" TextColor="#A0AEC0" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2"
                               Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf105;', Color='#CBD5E0', Size=16}"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- Change Password -->
                <Frame CornerRadius="14" Padding="16,14" HasShadow="False"
                       BorderColor="Transparent" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangePasswordTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="36, *, Auto">
                        <Frame Grid.Column="0" WidthRequest="36" HeightRequest="36"
                               CornerRadius="10" Padding="0" HasShadow="False"
                               BackgroundColor="#FAF5FF" BorderColor="Transparent">
                            <Image Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf023;', Color='#9F7AEA', Size=16}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center" Spacing="1">
                            <Label Text="Change Password" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" />
                            <Label Text="Send a password reset email" FontSize="11" TextColor="#A0AEC0" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2"
                               Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf105;', Color='#CBD5E0', Size=16}"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- Notifications -->
                <Frame CornerRadius="14" Padding="16,14" HasShadow="False"
                       BorderColor="Transparent" BackgroundColor="White">
                    <Grid ColumnDefinitions="36, *, Auto">
                        <Frame Grid.Column="0" WidthRequest="36" HeightRequest="36"
                               CornerRadius="10" Padding="0" HasShadow="False"
                               BackgroundColor="#FFFFF0" BorderColor="Transparent">
                            <Image Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf0f3;', Color='#ECC94B', Size=16}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center" Spacing="1">
                            <Label Text="Notifications" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" />
                            <Label Text="Manage your alerts" FontSize="11" TextColor="#A0AEC0" />
                        </VerticalStackLayout>
                        <Switch x:Name="NotificationsSwitch"
                                Grid.Column="2"
                                OnColor="#4DBBB7"
                                VerticalOptions="Center"
                                Toggled="OnNotificationToggled" />
                    </Grid>
                </Frame>

            </VerticalStackLayout>

            <!-- ─── App Info ───────────────────────────────────────── -->
            <Label Text="App" FontSize="13" FontAttributes="Bold"
                   TextColor="#718096" Margin="25,20,20,8" />

            <VerticalStackLayout Margin="20,0" Spacing="10">

                <!-- About -->
                <Frame CornerRadius="14" Padding="16,14" HasShadow="False"
                       BorderColor="Transparent" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAboutTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="36, *, Auto">
                        <Frame Grid.Column="0" WidthRequest="36" HeightRequest="36"
                               CornerRadius="10" Padding="0" HasShadow="False"
                               BackgroundColor="#F0FFF4" BorderColor="Transparent">
                            <Image Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf05a;', Color='#48BB78', Size=16}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center" Spacing="1">
                            <Label Text="About ExploreCebu" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" />
                            <Label Text="Version 1.0.0" FontSize="11" TextColor="#A0AEC0" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2"
                               Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf105;', Color='#CBD5E0', Size=16}"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- Rate App -->
                <Frame CornerRadius="14" Padding="16,14" HasShadow="False"
                       BorderColor="Transparent" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRateAppTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="36, *, Auto">
                        <Frame Grid.Column="0" WidthRequest="36" HeightRequest="36"
                               CornerRadius="10" Padding="0" HasShadow="False"
                               BackgroundColor="#FFFAF0" BorderColor="Transparent">
                            <Image Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf005;', Color='#F6AD55', Size=16}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center" Spacing="1">
                            <Label Text="Rate the App" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" />
                            <Label Text="Enjoying ExploreCebu? Let us know!" FontSize="11" TextColor="#A0AEC0" />
                        </VerticalStackLayout>
                        <Image Grid.Column="2"
                               Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf105;', Color='#CBD5E0', Size=16}"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

            </VerticalStackLayout>

            <!-- ─── Logout ─────────────────────────────────────────── -->
            <Button Text="Log Out"
                    Clicked="OnLogoutClicked"
                    TextColor="White"
                    BackgroundColor="#E53E3E"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Margin="20,25,20,10" />

            <Label Text="ExploreCebu v1.0.0"
                   FontSize="11"
                   TextColor="#CBD5E0"
                   HorizontalOptions="Center"
                   Margin="0,0,0,30" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>