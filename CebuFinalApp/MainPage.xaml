<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CebuFinalApp.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F4F9F8">

    <Grid RowDefinitions="Auto, *">
        <BoxView Grid.Row="0" HeightRequest="60" Color="#4FD1C5" />
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,0" HeightRequest="60">
            <Label Text="Explore Cebu" TextColor="White" FontSize="22" FontAttributes="Bold" 
                   VerticalOptions="Center" HorizontalOptions="Center" Margin="30,0,0,0"/>
            <Image Grid.Column="1" Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf002;', Color=White, Size=20}" 
                   VerticalOptions="Center" />
        </Grid>

        <Grid Grid.Row="1">
            <WebView x:Name="MapWebView" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" />

            <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="End" Margin="0,20,20,0" Spacing="15">
                <Frame HeightRequest="50" WidthRequest="50" CornerRadius="25" Padding="0" HasShadow="True" 
                       BorderColor="Transparent" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLayersClicked" />
                    </Frame.GestureRecognizers>
                    <Image Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf5fd;', Color='#333333', Size=20}" 
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>

                <Frame HeightRequest="50" WidthRequest="50" CornerRadius="25" Padding="0" HasShadow="True" 
                       BorderColor="Transparent" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGPSClicked" />
                    </Frame.GestureRecognizers>
                    <Image Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf124;', Color='#333333', Size=20}" 
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout VerticalOptions="End" Margin="20,0,20,30">
                <Frame CornerRadius="30" HasShadow="True" Padding="15,0" HeightRequest="60" 
                       BackgroundColor="White" BorderColor="Transparent">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Image Grid.Column="0" Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf002;', Color='#333333', Size=20}" 
                               VerticalOptions="Center" Margin="0,0,10,0"/>

                        <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="Search places..." FontSize="16" 
                               TextColor="#333333" VerticalOptions="Center" BackgroundColor="Transparent"
                               ReturnType="Search" Completed="OnSearchCompleted" />

                        <ImageButton x:Name="MicButton" Grid.Column="2" BackgroundColor="Transparent" 
                                     Clicked="OnMicClicked" HeightRequest="45" WidthRequest="45" Padding="12"
                                     Source="{FontImageSource FontFamily=FASolid, Glyph='&#xf130;', Color='#333333', Size=18}" 
                                     VerticalOptions="Center" />
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>